# Book settings
# Learn more at https://jupyterbook.org/customize/config.html

title: @LUE_TITLE@
copyright: 2016-now -- This work is licensed under Creative Commons Attribution 4.0 International (CC-BY-4.0)
author: @LUE_AUTHOR@
logo: lue_logo-colour.svg

# Force re-execution of notebooks on each build.
# See https://jupyterbook.org/content/execute.html
execute:
  execute_notebooks: force

# Define the name of the latex output file for PDF builds
latex:
  latex_documents:
    targetname: @LUE_BOOK_BASENAME@.tex

# Add a bibtex file so that we can create citations
bibtex_bibfiles:
  - references.bib

# Information about where the book exists on the web
repository:
  url: @CMAKE_PROJECT_HOMEPAGE_URL@
  # path_to_book: doc  # Optional path to your book, relative to the repository root
  branch: master  # Which branch of the repository should be used when creating links (optional)

# Add GitHub buttons to your book
# See https://jupyterbook.org/customize/config.html
html:
  use_issues_button: true
  use_repository_button: true
  baseurl: https://lue.computationalgeography.org/doc
  extra_footer: |
    <p>
    <a href="https://lue.computationalgeography.org">
        <!-- TODO: where the logo?! -->
        <img src="/_static/lue_logo-colour.svg" width="50" alt="LUE home"/>
    </a>
    </p>
sphinx:
  config:

    bibtex_reference_style: author_year

    html_theme_options:
      # repository_url: https://example.com/thing
      use_issues_button: false
      use_download_button: false
      use_repository_button: false
      use_edit_page_button: false
      home_page_in_toc: false
      logo:
        image_light: lue_logo-colour.svg
        image_dark: lue_logo-colour.svg

    html_context:
      default_mode: light

    # https://breathe.readthedocs.io/en/latest/index.html
    # https://breathe.readthedocs.io/en/latest/directives.html#config-values
    breathe_projects: {
      "lue": "@DOXYGEN_OUTPUT_DIR@/xml/"
    }
    breathe_default_project: "lue"
    breathe_default_members:
        - "members"
    breathe_show_include: True

    # # https://sphinx-autodoc2.readthedocs.io/en/latest/index.html
    # autodoc2_packages:
    #   # - "@AUTODOC2_PACKAGE_DIR@"
    #   - {
    #       "path": "@AUTODOC2_PACKAGE_DIR@",
    #       "module": "lue.framework"
    #   }
    # autodoc2_output_dir: "reference/python/apidocs"

    autodoc_default_options: {
        "members": True,
        "undoc-members": True
    }

    intersphinx_mapping: {
        "python": ["https://docs.python.org/3", null],
        "numpy": ["https://numpy.org/doc/stable", null]
    }

    intersphinx_disabled_reftypes: ["*"]

    # bibtex_default_style: "plain"

  extra_extensions:
    # - "sphinx.ext.pngmath"
    - "sphinx.ext.todo"
    - "breathe"
    # - "autodoc2"
    - "sphinx.ext.autodoc"
    # - "sphinx.ext.autosummary"
    - "sphinx.ext.graphviz"
    - "sphinx.ext.intersphinx"
    - "sphinxcontrib.mermaid"
    - "sphinxcontrib.bibtex"

parse:
  # https://jupyterbook.org/en/stable/content/content-blocks.html#myst-syntax-extensions
  # https://myst-parser.readthedocs.io/en/latest/syntax/optional.html
  myst_enable_extensions:
    - amsmath
    - attrs_inline
    - dollarmath
    - html_image
    - linkify
    # - aside
    # - deflist
    # - colon_fence  # Don't use this. Syntax is already confusing enough.
